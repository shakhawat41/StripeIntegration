# =============================================================================
# Environment Variables — Stripe Payment Integration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains secrets.
# =============================================================================

# --- Stripe API Keys ---
# Obtain from: https://dashboard.stripe.com/test/apikeys
# Use the "Secret key" (starts with sk_test_) for backend API calls.
STRIPE_API_KEY=sk_test_your_stripe_secret_key_here

# Obtain from: Stripe Dashboard → Developers → Webhooks → Signing secret
# Used to verify incoming webhook event signatures.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# --- PostgreSQL Database ---
# Database name used by the application and seeder containers.
POSTGRES_DB=payment_processing

# Database credentials — used by both the PostgreSQL container and the app.
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# --- OpenTelemetry ---
# OTLP gRPC endpoint for the OTel Collector.
# In Docker Compose, this points to the otel-collector service.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
